.env
.env.*
.git
.gitignore
docker-compose.yml

# Python artifacts
**/__pycache__/
**/*.py[cod]

# Node artifacts
frontend/node_modules/
frontend/build/

# Local uploads and generated assets
backend/uploads/
models/*
!models/prepare.py
!models/requirements.txt
