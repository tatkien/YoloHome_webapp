# Docker Compose local environment
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_local
POSTGRES_DB=yolohome

# --- MQTT ---
MQTT_BROKER_URL=mqtt
MQTT_PORT=1883
MQTT_KEEPALIVE=60

# --- Backend Runtime ---
DATABASE_URL=postgresql+asyncpg://postgres:change_me_local@db:5432/yolohome
SECRET_KEY=change_me_local
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
WS_IDLE_TIMEOUT_SECONDS=60
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SETUP_CODE=yolohome2024
ADMIN_RESET_MODE=false

# --- AI: Face Recognition ---
RETINAFACE_MODEL_PATH=/models/face/det_10g.onnx
ARCFACE_MODEL_PATH=/models/face/arcface_resnet100.onnx
ANTISPOOF_MODEL_PATH=/models/face/MiniFASNetV2.onnx
FACE_MATCH_THRESHOLD=0.4
FACE_DETECTION_THRESHOLD=0.6

# --- AI: Voice Control ---
IP_WEBCAM_AUDIO_URL=http://192.168.1.10:8080/audio.wav
WHISPER_MODEL_PATH=/models/voice/whisper
KWS_MODEL_DIR=/models/voice/kws/sherpa-onnx-kws-zipformer-gigaspeech-3.3M-2024-01-01
WAKE_WORDS=hey computer,super hero,go home,hello home

# --- Hardware & System ---
SERVER_ID=SERVER_NODE
SERVO_AUTO_CLOSE_DELAY_MS=5000

# --- Data Retention ---
SENSOR_RETENTION_DAYS=30
DEVICE_LOG_RETENTION_DAYS=7
LOG_RETENTION_DAYS=7
