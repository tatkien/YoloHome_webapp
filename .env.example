# Docker Compose local environment
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_local
POSTGRES_DB=yolohome

#MQTT
MQTT_BROKER_URL=mqtt
MQTT_PORT=1883

# Backend runtime
DATABASE_URL=postgresql+asyncpg://postgres:change_me_local@db:5432/yolohome
SECRET_KEY=change_me_local
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
SETUP_CODE=yolohome2024

# Face recognition model paths (override if models are stored elsewhere)
ARCFACE_MODEL_PATH=/models/arcface_resnet100.onnx
RETINAFACE_MODEL_PATH=/models/det_10g.onnx
FACE_MATCH_THRESHOLD=0.4
FACE_DETECTION_THRESHOLD=0.6

# Voice control IP Webcam Audio Source
IP_WEBCAM_AUDIO_URL=http://10.137.229.48:8080/audio.wav
WAKE_WORD=hey_javis
